// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Template {
  id        Int      @id @default(autoincrement())
  title     String
  config    Json
  active    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ShopSettings {
  id                           Int      @id @default(autoincrement())
  shop                         String   @unique
  recommendation_popup_enabled Boolean  @default(false)
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt
}

model ProductRecommendation {
  id                       Int      @id @default(autoincrement())
  shop                     String
  triggerProductId         String
  triggerProductTitle      String
  triggerProductHandle     String?
  triggerProductImage      String?
  recommendedProductId     String
  recommendedProductTitle  String
  recommendedProductHandle String?
  recommendedProductImage  String?
  popupTitle               String   @default("You might also like")
  ctaText                  String   @default("Add to Combo")
  dismissText              String   @default("No thanks")
  active                   Boolean  @default(true)
  createdAt                DateTime @default(now())
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
}
