{% schema %}
{
  "name": "Combo Builder (Dynamic)",
  "target": "body",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_sold_out_products",
      "label": "Show sold out products",
      "default": false
    }
  ]
}
{% endschema %}

<div id="combo-builder-root" data-show-sold-out-products='{{ block.settings.show_sold_out_products | json }}' style="display:none; min-height: 400px; position: relative; font-family: inherit;">
  <div id="loading-combo" style="text-align: center; padding: 60px 20px;">
    <div class="cdo-spinner"></div>
    <p style="margin-top: 15px; color: #666; font-family: inherit;">Loading your combo builder...</p>
  </div>
</div>
<div class="summa"></div>
<style>
    /* Spinner for checkout button (override for visibility and size) */
    #cdo-checkout-btn .cdo-spinner {
      width: 28px !important;
      height: 28px !important;
      border-width: 3px !important;
      border-color: #fff #fff #fff #333 !important;
      background: transparent !important;
      position: absolute !important;
      top: 50% !important;
      left: 50% !important;
      transform: translate(-50%, -50%) !important;
      margin: 0 !important;
      z-index: 2 !important;
      display: none;
    }
  .cdo-spinner { width: 40px; height: 40px; border: 3px solid #f3f3f3; border-top: 3px solid #333; border-radius: 50%; animation: spin 1s linear infinite; margin: 0 auto; }
  @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
  .cdo-toast { position: fixed; bottom: 100px; left: 50%; transform: translateX(-50%) translateY(100px); background: #111; color: #fff; padding: 14px 28px; border-radius: 50px; z-index: 10000; opacity: 0; transition: all 0.4s; pointer-events: none; }
  .cdo-toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
  .cdo-qty-btn { width: 40px; height: 40px; border: 1px solid #e0e0e0; background: #fff; cursor: pointer; font-size: 20px; display: flex; align-items: center; justify-content: center; touch-action: manipulation; }
  .cdo-qty-value { width: 36px; height: 40px; text-align: center; border: 1px solid #e0e0e0; border-left: none; border-right: none; appearance: none; -webkit-appearance: none; background: #fff; font-size: 14px; }
  .cdo-card { position: relative; }
  .cdo-card.cdo-sold-out {
    filter: grayscale(100%);
    opacity: 0.72;
  }
  .cdo-card.cdo-sold-out .cdo-add-btn,
  .cdo-card.cdo-sold-out .cdo-qty-btn {
    cursor: not-allowed;
    opacity: 0.7;
  }
  .cdo-soldout-pill {
    position: absolute;
    left: 8px;
    top: 8px;
    z-index: 3;
    background: rgba(0, 0, 0, 0.78);
    color: #fff;
    font-size: 10px;
    font-weight: 700;
    padding: 4px 8px;
    border-radius: 999px;
    letter-spacing: 0.4px;
    text-transform: uppercase;
  }
  .cdo-tick { position: absolute; top: 8px; right: 8px; width: 22px; height: 22px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 13px; color: #fff; font-weight: 700; display: none; z-index: 2; }
  .cdo-tick.visible { display: flex; }
  /* Progress bar */
  #cdo-progress-track {
    position: relative;
    overflow: hidden;
    border-radius: 10px;
    background: #e0e0e0;
    height: 10px;
    width: 100%;
    box-shadow: inset 0 0 0 10px #e0e0e0;
  }
  #cdo-progress-bar {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    width: 100%;
    transform-origin: left center;
    transform: scaleX(0);
    transition: transform 0.55s cubic-bezier(0.4,0,0.2,1), background-color 0.35s ease;
    background: var(--cdo-progress-color, #1a6644);
  }
  #cdo-progress-bar-fill {
    position: absolute;
    inset: 0;
    background: var(--cdo-progress-color, #1a6644);
    border-radius: 10px;
    transition: background-color 0.35s ease;
  }
  /* Timer (layout3) */
  .cdo-timer { display: flex; gap: 8px; justify-content: center; align-items: center; }
  .cdo-timer-unit { display: flex; flex-direction: column; align-items: center; }
  .cdo-timer-val { font-size: 28px; font-weight: 800; line-height: 1; }
  .cdo-timer-label { font-size: 10px; text-transform: uppercase; letter-spacing: 1px; opacity: 0.7; }
  .cdo-timer-sep { font-size: 24px; font-weight: 800; padding-bottom: 6px; }
  /* Banner Slider (layout3 only) */
  .cdo-slider { position: relative; overflow: hidden; }
  .cdo-slider-track { display: flex; transition: transform 0.5s ease; }
  .cdo-slider-slide { flex-shrink: 0; width: 100%; }
  .cdo-slider-dots { position: absolute; bottom: 10px; left: 50%; transform: translateX(-50%); display: flex; gap: 6px; }
  .cdo-slider-dot { width: 8px; height: 8px; border-radius: 50%; background: rgba(255,255,255,0.5); cursor: pointer; transition: background 0.3s; }
  .cdo-slider-dot.active { background: #fff; }

  /* Collection tabs (layout2) */
  .cdo-tabs-viewport {
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    scroll-behavior: smooth;
    padding-bottom: 2px;
  }
  .cdo-tabs-wrap {
    position: relative;
  }
  .cdo-tabs-wrap.cdo-tabs-mode-scroll .cdo-tabs-viewport {
    scrollbar-width: thin;
    scrollbar-color: rgba(0, 0, 0, 0.25) transparent;
  }
  .cdo-tabs-wrap.cdo-tabs-mode-arrows .cdo-tabs-viewport,
  .cdo-tabs-wrap.cdo-tabs-mode-slide_touch .cdo-tabs-viewport {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .cdo-tabs-wrap.cdo-tabs-mode-arrows .cdo-tabs-viewport::-webkit-scrollbar,
  .cdo-tabs-wrap.cdo-tabs-mode-slide_touch .cdo-tabs-viewport::-webkit-scrollbar {
    display: none;
  }
  .cdo-tabs-wrap.cdo-tabs-mode-slide_touch .cdo-tabs-viewport {
    touch-action: pan-x;
  }
  .cdo-tabs-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 4;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    border: 1px solid #d7d7d7;
    background: #fff;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 3px 10px rgba(0,0,0,0.12);
  }
  .cdo-tabs-arrow.prev { left: 6px; }
  .cdo-tabs-arrow.next { right: 6px; }
  .cdo-tabs-arrow:hover {
    background: #f7f7f7;
  }
  .cdo-tabs-viewport::-webkit-scrollbar {
    height: 5px;
  }
  .cdo-tabs-viewport::-webkit-scrollbar-track {
    background: transparent;
  }
  .cdo-tabs-viewport::-webkit-scrollbar-thumb {
    background: rgba(0, 0, 0, 0.25);
    border-radius: 999px;
  }
  .cdo-tab-row {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    gap: 10px;
    width: max-content;
    min-width: 100%;
    white-space: nowrap;
    scroll-snap-type: x proximity;
  }
  .cdo-tab {
    flex: 0 0 auto;
    white-space: nowrap;
    scroll-snap-align: start;
    border: none;
    outline: none;
    line-height: 1.2;
  }
  .cdo-tab:focus-visible {
    box-shadow: 0 0 0 3px rgba(0, 96, 223, 0.35);
  }

  .cdo-products-region {
    position: relative;
  }
  .cdo-products-grid {
    transition: opacity 0.18s ease;
  }
  .cdo-products-grid.is-loading {
    opacity: 0.7;
  }
  .cdo-products-skeleton {
    display: grid;
    grid-template-columns: inherit;
    gap: inherit;
    width: 100%;
  }
  .cdo-skeleton-card {
    border-radius: 12px;
    border: 1px solid #ececec;
    background: #fff;
    padding: 10px;
    overflow: hidden;
  }
  .cdo-skeleton-img,
  .cdo-skeleton-line {
    background: linear-gradient(90deg, #f1f1f1 25%, #e7e7e7 37%, #f1f1f1 63%);
    background-size: 400% 100%;
    animation: cdo-skeleton-shimmer 1.2s ease infinite;
  }
  .cdo-skeleton-img {
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: 8px;
    margin-bottom: 10px;
  }
  .cdo-skeleton-line {
    height: 12px;
    border-radius: 6px;
    margin-bottom: 8px;
  }
  .cdo-skeleton-line.short {
    width: 45%;
    margin-bottom: 0;
  }
  @keyframes cdo-skeleton-shimmer {
    0% { background-position: 100% 0; }
    100% { background-position: 0 0; }
  }
  /* Product Cards Slider */
  .cdo-layout-slider-container { position: relative; width: 100%; }
  .cdo-layout-slider {
    display: flex !important;
    gap: 16px;
    overflow-x: auto !important;
    padding-bottom: 15px !important;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
    scroll-behavior: smooth;
  }
  .cdo-layout-slider::-webkit-scrollbar { display: none; }
  .cdo-layout-slider .cdo-card { 
    min-width: clamp(170px, 42vw, 240px) !important; 
    width: clamp(170px, 42vw, 240px) !important; 
    flex-shrink: 0 !important; 
    scroll-snap-align: start;
  }
  .cdo-card-actions { display: flex; align-items: center; gap: 8px; margin-top: auto; }
  .cdo-qty-wrap { display: inline-flex; align-items: center; }
  .cdo-add-btn { min-height: 40px; touch-action: manipulation; }
  .cdo-nav-btn {
    position: absolute; top: 50%; transform: translateY(-50%);
    width: 40px; height: 40px; border-radius: 50%; background: #fff;
    border: 1px solid #ddd; display: flex; align-items: center; justify-content: center;
    cursor: pointer; z-index: 10; box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    font-size: 18px; transition: all 0.2s;
  }
  .cdo-nav-btn:hover { background: #f8f8f8; box-shadow: 0 6px 15px rgba(0,0,0,0.15); }
  .cdo-nav-btn.prev { left: 10px; }
  .cdo-nav-btn.next { right: 10px; }
  @media (max-width: 1024px) {
    .cdo-layout-slider .cdo-card {
      min-width: clamp(165px, 52vw, 220px) !important;
      width: clamp(165px, 52vw, 220px) !important;
    }
  }
  @media (max-width: 768px) {
    .cdo-nav-btn { display: none; }
    .cdo-layout-slider .cdo-card {
      min-width: clamp(160px, 68vw, 200px) !important;
      width: clamp(160px, 68vw, 200px) !important;
    }
    .cdo-card-actions { flex-wrap: wrap; }
    .cdo-qty-wrap,
    .cdo-add-btn {
      width: 100%;
    }
  }
  @media (max-width: 480px) {
    .cdo-layout-slider .cdo-card {
      min-width: 78vw !important;
      width: 78vw !important;
    }
  }
  .cdo-variant-hover-popup { position: absolute; bottom: 0; left: 0; right: 0; background: rgba(255,255,255,0.95); padding: 8px; transform: translateY(100%); transition: transform 0.2s ease; z-index: 10; display: flex; flex-wrap: wrap; gap: 4px; max-height: 100px; overflow-y: auto; border-top: 1px solid #eee; }
  .cdo-card:hover .cdo-variant-hover-popup { transform: translateY(0); }
  .cdo-variant-swatch { font-size: 10px; padding: 4px 8px; border: 1px solid #ddd; border-radius: 4px; background: #fff; cursor: pointer; transition: all 0.2s; color: #333; font-weight: 600; }
  .cdo-variant-swatch:hover { border-color: #000; background: #f9f9f9; }
  .cdo-variant-swatch.active { background: #000; color: #fff; border-color: #000; }
  .cdo-img-wrapper {
    position: relative;
    overflow: hidden;
    border-radius: 8px;
    margin-bottom: 10px;
    aspect-ratio: var(--cdo-image-ratio, 1 / 1);
  }
  @supports not (aspect-ratio: 1 / 1) {
    .cdo-img-wrapper {
      height: 0;
      padding-top: var(--cdo-image-ratio-fallback, 100%);
    }
    .cdo-img-wrapper > img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
  }

  /* Preview bar slot/image alignment */
  #cdo-preview-bar #cdo-slots {
    justify-content: flex-start;
    align-items: center;
  }
  #cdo-preview-bar [id^="cdo-slot-"] {
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  #cdo-preview-bar .cdo-preview-image,
  #cdo-preview-bar .preview-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    border-radius: inherit;
  }

  @media (max-width: 1024px) {
    #cdo-preview-bar #cdo-slots {
      width: 100%;
      justify-content: center;
      margin-left: auto;
      margin-right: auto;
    }
  }

  @media (max-width: 768px) {
    #cdo-preview-bar #cdo-slots {
      gap: 8px;
    }
  }
</style>

<script>
/* ===================== UTILITIES ===================== */
function formatMoney(cents) {
  const num = parseFloat(cents);
  let currency = '₹';
  if (typeof window !== 'undefined' && window.Shopify && window.Shopify.currency && window.Shopify.currency.active) {
    const symbols = { USD: '$', EUR: '€', GBP: '£', INR: '₹', JPY: '¥', AUD: 'A$', CAD: 'C$', SGD: 'S$', HKD: 'HK$', CNY: '¥', RUB: '₽', BRL: 'R$', ZAR: 'R', TRY: '₺', IDR: 'Rp', THB: '฿', MYR: 'RM', PHP: '₱', VND: '₫', KRW: '₩', NGN: '₦', MXN: '$', PLN: 'zł', CZK: 'Kč', SEK: 'kr', DKK: 'kr', NOK: 'kr', HUF: 'Ft', CHF: 'Fr', NZD: 'NZ$', TWD: 'NT$', SAR: '﷼', AED: 'د.إ', ILS: '₪' };
    currency = symbols[window.Shopify.currency.active] || window.Shopify.currency.active;
  }
  if (!Number.isFinite(num)) return `${currency}0.00`;
  if (typeof cents === 'string' && cents.includes('.')) return `${currency}${num.toFixed(2)}`;
  return `${currency}${(num / 100).toFixed(2)}`;
}

function showToast(msg) {
  let t = document.getElementById('combo-toast');
  if (!t) { t = document.createElement('div'); t.id = 'combo-toast'; t.className = 'cdo-toast'; document.body.appendChild(t); }
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 3000);
}



/* ===================== VISITOR TRACKING ===================== */
function trackVisit(templateName) {
  if (!templateName) return;
  let userId = sessionStorage.getItem('cdo_uid');
  if (!userId) {
    userId = 'visitor-' + Math.random().toString(36).substr(2, 9);
    sessionStorage.setItem('cdo_uid', userId);
  }
  const payload = {
    template_name: templateName,
    template_id: '123', // Replace with actual template ID if available
    shop_domain: window.Shopify && window.Shopify.shop ? window.Shopify.shop : 'unknown.myshopify.com',
    page_url: window.location.href,
    visitor_id: userId
  };
  fetch('https://darkblue-dotterel-303283.hostingersite.com/clicks.php', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json'
    },
    body: JSON.stringify(payload)
  });
}

function isProductInStock(product) {
  if (!product || product.available === false) return false;
  const variants = Array.isArray(product.variants) ? product.variants : [];

  if (!variants.length) {
    const productInventory = parseInt(product.inventory_quantity, 10);
    if (Number.isFinite(productInventory)) return productInventory > 0;
    return product.available !== false;
  }

  return variants.some(variant => {
    if (variant.available === false) return false;
    const inventory = parseInt(variant.inventory_quantity, 10);
    if (Number.isFinite(inventory)) return inventory > 0;
    return variant.available !== false;
  });
}

function filterProductsByStock(products, cfg) {
  const list = Array.isArray(products) ? products : [];
  if (cfg && cfg.show_sold_out_products === true) return list;
  return list.filter(isProductInStock);
}

function getProductImageRatio(cfg) {
  const ratio = (cfg && cfg.product_image_ratio) || 'square';
  if (ratio === 'portrait') return { cssRatio: '3 / 4', fallbackPadding: '133.3333%' };
  if (ratio === 'rectangle') return { cssRatio: '4 / 3', fallbackPadding: '75%' };
  return { cssRatio: '1 / 1', fallbackPadding: '100%' };
}


/* ===================== PRODUCT CARD ===================== */
function renderProductCard(cfg, product) {
  const viewport   = window.innerWidth || document.documentElement.clientWidth || 1024;
  const isMobile   = viewport < 768;
  const isTablet   = viewport >= 768 && viewport < 1024;
  const titleSize  = isMobile ? (cfg.product_title_size_mobile  || 13) : (cfg.product_title_size_desktop  || 15);
  const priceSize  = isMobile ? (cfg.product_price_size_mobile  || 13) : (cfg.product_price_size_desktop  || 15);
  const imgRatio = getProductImageRatio(cfg);
  const cardPad    = cfg.product_card_padding ?? 10;
  const borderColor= cfg.preview_item_border_color || '#f0f0f0';
  const addBtnText = cfg.add_btn_text || cfg.product_add_btn_text || 'Add';
  const addBtnBg   = cfg.add_btn_bg || cfg.product_add_btn_color || '#000';
  const addBtnColor= cfg.add_btn_text_color || cfg.product_add_btn_text_color || '#fff';
  const addBtnSize = isMobile
    ? Math.min(cfg.add_btn_font_size || cfg.product_add_btn_font_size || 14, 14)
    : (cfg.add_btn_font_size || cfg.product_add_btn_font_size || 14);
  const addBtnW    = cfg.add_btn_font_weight || cfg.product_add_btn_font_weight || 600;
  const addBtnRadius = cfg.add_btn_border_radius ?? 8;
  const showQty    = cfg.show_quantity_selector !== false;
  const showTick   = cfg.show_selection_tick !== false;
  const hlColor    = cfg.selection_highlight_color || cfg.primary_color || '#000';
  const soldOut    = !isProductInStock(product);
  let productId = (product.id || '').replace('gid://shopify/Product/', '');
  // If only one variant, use variant ID for data-id
  if (product.variants && product.variants.length === 1) {
    productId = (product.variants[0].id || '').replace('gid://shopify/ProductVariant/', '');
  }
  
  const variants = product.variants || [];
  const hasVariants = variants.length > 1;
  const displayMode = cfg.product_card_variants_display || 'popup';
  
  let variantsHtml = '';
  if (hasVariants && displayMode === 'hover') {
    variantsHtml = `
    <div class="cdo-variant-hover-popup">
      ${variants.map(v => {
        const vId = (v.id || '').replace('gid://shopify/ProductVariant/', '');
        return `<div class="cdo-variant-swatch" data-variant-id="${vId}" data-price="${v.price}" data-image="${v.image || product.image || ''}" title="${v.title}">
          ${v.title}
        </div>`;
      }).join('')}
    </div>`;
  }

  return `
  <div class="cdo-card ${soldOut ? 'cdo-sold-out' : ''}" data-id="${productId}" data-price="${product.price}" data-image="${product.image || ''}" data-step="${product.step || 1}" data-steplimit="${product.step_limit || ''}" data-collection="${product.collection_handle || ''}" data-soldout="${soldOut ? '1' : '0'}"
       style="border:2px solid ${borderColor};border-radius:12px;padding:${cardPad}px;background:#fff;display:flex;flex-direction:column;transition:border-color 0.2s;overflow:hidden;">
    ${soldOut ? `<div class="cdo-soldout-pill">Sold Out</div>` : ''}
    ${showTick ? `<div class="cdo-tick" style="background:${hlColor};">✓</div>` : ''}
    <div class="cdo-img-wrapper" style="--cdo-image-ratio:${imgRatio.cssRatio};--cdo-image-ratio-fallback:${imgRatio.fallbackPadding};">
      <img src="${product.image || ''}" alt="${product.title || ''}" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;">
      ${variantsHtml}
    </div>
    <div style="font-size:${titleSize}px;font-weight:700;margin-bottom:4px;color:${cfg.text_color||'#111'};line-height:1.3;">${product.title || ''}</div>
    <div style="font-weight:800;font-size:${priceSize}px;color:${cfg.primary_color||cfg.add_btn_bg||'#000'};margin-bottom:10px;" class="cdo-card-price">${formatMoney(product.price)}</div>
    <div class="cdo-card-actions" style="margin-top:auto;display:flex;align-items:center;gap:6px;${showQty && isMobile ? 'flex-wrap:wrap;' : ''}">
      ${showQty ? `
      <div class="cdo-qty-wrap" style="display:flex;align-items:center;${isMobile ? 'width:100%;' : ''}">
        <button type="button" class="cdo-qty-btn decrement-btn" style="border-radius:6px 0 0 6px;">−</button>
        <input type="number" class="cdo-qty-value" value="0" readonly>
        <button type="button" class="cdo-qty-btn increment-btn" style="border-radius:0 6px 6px 0;">+</button>
      </div>` : ''}
      <button type="button" class="cdo-add-btn"
        style="flex:1;background:${addBtnBg};color:${addBtnColor};border:none;padding:${isMobile ? 10 : 8}px 12px;border-radius:${addBtnRadius}px;font-weight:${addBtnW};font-size:${addBtnSize}px;cursor:pointer;min-height:40px;">
        ${addBtnText}
      </button>
    </div>
  </div>`;
}

/* ===================== PREVIEW BAR HTML ===================== */
function getPreviewBarHtml(cfg) {
  if (cfg.show_preview_bar === false) return '';
  const viewport = window.innerWidth || document.documentElement.clientWidth || 1024;
  const isMobile = viewport < 768;
  const isTablet = viewport >= 768 && viewport < 1024;
  const max      = parseInt(cfg.max_products) || 5;
  const shape    = cfg.preview_item_shape === 'circle' ? '50%' : (cfg.preview_border_radius || 8) + 'px';
  const baseItemSize = cfg.preview_item_size || 56;
  const itemSize = isMobile ? Math.min(baseItemSize, 44) : (isTablet ? Math.min(baseItemSize, 50) : baseItemSize);
  const borderColor = cfg.preview_item_border_color || 'rgba(0,0,0,0.2)';
  const padTop   = cfg.preview_bar_padding_top    ?? cfg.preview_bar_padding ?? 16;
  const padBot   = cfg.preview_bar_padding_bottom ?? cfg.preview_bar_padding ?? 16;
  const padH     = isMobile ? 12 : (isTablet ? 14 : 16);
  const fullW    = cfg.preview_bar_full_width !== false;
  const radius   = cfg.preview_border_radius || 0;

  let slotsHtml = '';
  for (let i = 1; i <= max; i++) {
    slotsHtml += `<div id="cdo-slot-${i}" style="width:${itemSize}px;height:${itemSize}px;border:2px dashed ${borderColor};border-radius:${shape};display:flex;align-items:center;justify-content:center;color:rgba(0,0,0,0.3);font-size:18px;flex-shrink:0;overflow:hidden;transition:all 0.3s;">+</div>`;
  }

