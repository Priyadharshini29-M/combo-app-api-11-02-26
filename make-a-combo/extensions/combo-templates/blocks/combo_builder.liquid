{% schema %}
{
  "name": "Combo Builder (Dynamic)",
  "target": "body",
  "settings": []
}
{% endschema %}

{{ 'combo-builder.css' | asset_url | stylesheet_tag }}

<div id="combo-builder-root" style="display:none; min-height: 400px; position: relative; font-family: inherit;">
  <div id="loading-combo" style="text-align: center; padding: 60px 20px;">
    <div class="cdo-spinner"></div>
    <p style="margin-top: 15px; color: #666; font-family: inherit;">Loading your combo builder...</p>
  </div>
</div>

{{ 'combo-extended.js' | asset_url | script_tag }}
